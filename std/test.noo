# std/test — Noolang's test framework.
#
# Shipped with the interpreter but written as plain userland noolang: no
# evaluator hooks, no typer access. Tests are values — a test file's last
# expression is its Test tree; the runner imports it and walks it.
# Design rationale: docs-wip/TESTING_FRAMEWORK_PLAN.md.
#
# Use the lowercase helpers (test_case, group, expect_*), not the raw
# constructors. The constructors are public only because the language cannot
# hide them; their payloads may change shape.

# Fail carries a structured payload so runners can render diffs and emit
# machine-readable output without re-parsing message strings.
variant Expectation =
    Pass
  | Fail {@message String, @expected Option String, @actual Option String};

# Case thunks declare the full effect row: tests may perform any effect, and
# over-declaring is legal, so pure and effectful test bodies both fit.
variant Test =
    Case String ({} -> Expectation !write !read !log !state !time !rand !ffi !async)
  | Group String (List Test);

test_case = fn name thunk => Case name thunk;
group = fn name tests => Group name tests;

fail = fn message => Fail {@message message, @expected None, @actual None};

# Expected comes first: partial application (expect_eq 4) and pipelines
# (compute x | expect_eq 4) both read correctly.
expect_eq = fn expected actual =>
  if expected == actual
  then Pass
  else Fail {
    @message "values are not equal",
    @expected Some (show expected),
    @actual Some (show actual)
  };

expect_neq = fn unexpected actual =>
  if unexpected == actual
  then Fail {
    @message "values are equal but should not be",
    @expected Some ("not " + show unexpected),
    @actual Some (show actual)
  }
  else Pass;

# The label is mandatory so a failed boolean check is never mute
expect = fn label condition =>
  if condition then Pass else fail label;

expect_ok = fn res => match res (
  Ok _ => Pass;
  Err e => fail ("expected Ok, got Err: " + show e)
);

expect_err = fn res => match res (
  Ok x => fail ("expected Err, got Ok: " + show x);
  Err _ => Pass
);

# First Fail wins — reports the earliest broken expectation
expect_all = fn expectations =>
  reduce (fn acc e => match acc (Pass => e; Fail info => Fail info)) Pass expectations;

# ========================================
# RUNNER
# ========================================

# The executed mirror of a Test tree. Execution (run_tree) is effectful —
# thunks carry the full effect row; everything after it is pure.
variant TestResult =
    CaseResult String Expectation
  | GroupResult String (List TestResult);

run_tree = fn t => match t (
  Case name thunk => CaseResult name (thunk {});
  Group name tests => GroupResult name (list_map run_tree tests)
);

no_counts = {@passed 0, @failed 0};

add_counts = fn a b => (
  {@passed a_passed, @failed a_failed} = a;
  {@passed b_passed, @failed b_failed} = b;
  {@passed a_passed + b_passed, @failed a_failed + b_failed}
);

result_counts = fn result => match result (
  CaseResult _ e => match e (
    Pass => {@passed 1, @failed 0};
    Fail _ => {@passed 0, @failed 1}
  );
  GroupResult _ results =>
    reduce (fn acc r => add_counts acc (result_counts r)) no_counts results
);

indent = fn depth =>
  if depth == 0 then "" else "  " + indent (depth - 1);

# Failure detail lines, indented under the case mark
format_failure = fn depth info => (
  pad = indent depth + "    ";
  expected = info | @expected;
  actual = info | @actual;
  match {expected, actual} (
    {Some e, Some a} => pad + "expected: " + e + "\n" + pad + "actual:   " + a;
    _ => pad + (info | @message)
  )
);

format_at = fn depth result => match result (
  CaseResult name e => match e (
    Pass => indent depth + "✓ " + name;
    Fail info => indent depth + "✗ " + name + "\n" + format_failure depth info
  );
  GroupResult name results =>
    indent depth + name + "\n" + join "\n" (list_map (format_at (depth + 1)) results)
);

format_result = format_at 0;

# Print each suite's report and a final summary; return counts so the caller
# (not the runner) decides the process exit code
run_all = fn suites => (
  totals = reduce
    (fn acc entry => (
      result = entry | @suite | run_tree;
      _p1 = entry | @path | println;
      _p2 = result | format_result | println;
      add_counts acc (result_counts result)
    ))
    no_counts
    suites;
  {@passed passed, @failed failed} = totals;
  _summary = println (show passed + " passed, " + show failed + " failed");
  totals
);

{
  @test_case test_case,
  @group group,
  @expect_eq expect_eq,
  @expect_neq expect_neq,
  @expect expect,
  @expect_ok expect_ok,
  @expect_err expect_err,
  @expect_all expect_all,
  @fail fail,
  @run_tree run_tree,
  @format_result format_result,
  @result_counts result_counts,
  @run_all run_all
}
